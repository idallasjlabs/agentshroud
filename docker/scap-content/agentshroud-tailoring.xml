<?xml version="1.0" encoding="UTF-8"?>
<!--
  AgentShroud Container Security Tailoring File
  Profile: CIS Debian 12 Standard (container-adapted)

  Deselects rules inapplicable to containerized environments:
    - PAM / password complexity (no local interactive logins)
    - systemd units (containers use process 1 directly)
    - cron / at scheduling (no job scheduler in container)
    - auditd (host-level; container uses Falco + Wazuh sidecar)
    - firewall / iptables (network isolation via Docker networks)
    - bootloader (no grub/efi in container)
    - physical media / USB (not applicable)

  IEC 62443 FR3, CIS Docker Benchmark v1.6.0 Section 4.
-->
<Tailoring xmlns="http://checklists.nist.gov/xccdf/1.2"
           id="xccdf_agentshroud_tailoring_container">

  <version time="2026-03-19T00:00:00">1</version>

  <Profile id="xccdf_agentshroud_profile_container_standard"
           extends="xccdf_org.ssgproject.content_profile_standard">
    <title>AgentShroud Container Standard (CIS-adapted)</title>
    <description>
      CIS Debian 12 Standard profile adapted for AgentShroud gateway container.
      Deselects rules that are inapplicable to non-interactive, read-only containers
      managed by Docker Compose with cap_drop ALL, no-new-privileges, and seccomp.
    </description>

    <!-- PAM / authentication — no interactive logins in container -->
    <select idref="xccdf_org.ssgproject.content_rule_set_password_hashing_algorithm_systemauth" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_set_password_hashing_algorithm_logindefs" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_accounts_password_pam_minlen" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_accounts_password_pam_minclass" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_accounts_password_pam_retry" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_accounts_password_pam_unix_remember" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_accounts_password_pam_dcredit" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_accounts_password_pam_ucredit" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_accounts_password_pam_ocredit" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_accounts_password_pam_lcredit" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_accounts_maximum_age_login_defs" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_accounts_minimum_age_login_defs" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_accounts_password_warn_age_login_defs" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_no_empty_passwords" selected="false"/>

    <!-- systemd — container uses process supervision, not systemd -->
    <select idref="xccdf_org.ssgproject.content_rule_service_auditd_enabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_service_crond_enabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_service_atd_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_service_avahi-daemon_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_service_cups_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_service_nfs_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_service_rpcbind_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_service_smb_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_service_squid_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_service_telnet_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_service_xinetd_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_systemd_target_multi-user" selected="false"/>

    <!-- auditd — host-level audit handled by Falco + Wazuh sidecars -->
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_login_events" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_usergroup_modification" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_networkconfig_modification" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_mac_modification" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_dac_modification_chmod" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_dac_modification_chown" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_privileged_commands" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_media_export" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_session_events" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_time_adjtimex" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_time_clock_settime" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_time_settimeofday" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_time_stime" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_time_watch_localtime" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_kernel_module_loading" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_file_deletion_events" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_sudoers_actions" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_audit_rules_sysadmin_actions" selected="false"/>

    <!-- firewall / network — isolation enforced by Docker network architecture -->
    <select idref="xccdf_org.ssgproject.content_rule_set_firewalld_default_zone" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_service_firewalld_enabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_package_firewalld_installed" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_package_iptables_installed" selected="false"/>

    <!-- bootloader — no grub in container -->
    <select idref="xccdf_org.ssgproject.content_rule_bootloader_password" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_bootloader_uefi_password" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_grub2_password" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_grub2_uefi_password" selected="false"/>

    <!-- physical media / removable storage — not applicable to containers -->
    <select idref="xccdf_org.ssgproject.content_rule_kernel_module_usb-storage_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_kernel_module_cramfs_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_kernel_module_freevxfs_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_kernel_module_hfs_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_kernel_module_hfsplus_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_kernel_module_jffs2_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_kernel_module_squashfs_disabled" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_kernel_module_udf_disabled" selected="false"/>

    <!-- cron / at scheduling — no job scheduler in container -->
    <select idref="xccdf_org.ssgproject.content_rule_file_permissions_crontab" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_file_permissions_cron_hourly" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_file_permissions_cron_daily" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_file_permissions_cron_weekly" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_file_permissions_cron_monthly" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_file_permissions_cron_d" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_restrict_at_cron_users" selected="false"/>

    <!-- sudo — no sudo in this container -->
    <select idref="xccdf_org.ssgproject.content_rule_sudo_require_authentication" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_sudo_add_nopasswd" selected="false"/>
    <select idref="xccdf_org.ssgproject.content_rule_package_sudo_installed" selected="false"/>
  </Profile>
</Tailoring>
