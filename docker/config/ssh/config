# AgentShroud SSH Allowlist
# Only hosts listed here can be reached via SSH from the bot container.
# This file is refreshed from the image on every container startup.
# To add a new approved host, add a Host block ABOVE the "Block all" section.
# IMPORTANT: Each approved host MUST include "ProxyCommand none" to override
# the wildcard block at the bottom.

Host host.docker.internal
    HostName host.docker.internal
    User agentshroud-bot
    Port 22
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
    PasswordAuthentication no
    PubkeyAuthentication yes
    StrictHostKeyChecking accept-new
    ServerAliveInterval 30
    ServerAliveCountMax 3
    ProxyCommand nc -X connect -x gateway:8181 %h %p

Host pi raspberrypi
    HostName raspberrypi
