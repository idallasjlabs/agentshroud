# ─── Block all other SSH connections ─────────────────────────────────────────
# SECURITY: Any host not listed above will fail immediately.
# Approved hosts tunnel through the gateway CONNECT proxy; the wildcard below
# blocks any host that isn't explicitly approved above.
Host *
    ProxyCommand /bin/false
