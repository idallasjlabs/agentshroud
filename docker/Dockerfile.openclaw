# SecureClaw Chat Service Container - Phase 3 MVP
# Goal: Working chat with Isaiah's personality + security hardening
# Base: Python 3.11 (stable)

FROM python:3.11-slim AS base

# Install system dependencies (minimal - curl for healthcheck, openscap for compliance scanning)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    libopenscap33 \
    openscap-common \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user (UID 1000)
RUN groupadd -g 1000 openclaw && \
    useradd -u 1000 -g openclaw -m -s /bin/bash openclaw

# Create workspace and app directories
RUN mkdir -p /workspace /app && \
    chown -R openclaw:openclaw /workspace /app

# Set working directory
WORKDIR /app

# Copy chatbot service files
COPY chatbot/requirements.txt .
COPY chatbot/main.py .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy SCAP content for compliance scanning
RUN mkdir -p /usr/share/xml/scap/ssg/content
COPY docker/scap-content/ssg-debian12-ds.xml /usr/share/xml/scap/ssg/content/

# OCI Image labels
LABEL org.opencontainers.image.title="SecureClaw OpenClaw Chat"
LABEL org.opencontainers.image.description="Isaiah persona chat service with Anthropic Claude API"
LABEL org.opencontainers.image.vendor="SecureClaw"
LABEL org.opencontainers.image.version="0.1.0"
LABEL org.opencontainers.image.source="https://github.com/ijefferson/oneclaw"

# Prevent Python bytecode generation (read-only filesystem compatibility)
ENV PYTHONDONTWRITEBYTECODE=1

# Switch to non-root user
USER openclaw

# Expose chat service port (localhost only in docker-compose)
EXPOSE 18789

# Healthcheck - verify service is responding
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:18789/health || exit 1

# Start chat service
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "18789"]
