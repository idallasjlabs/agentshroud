# SecureClaw OpenClaw Container - Real OpenClaw Platform
# Goal: Full OpenClaw features (agents, skills, MCP) with bot identity
# Base: Node.js 22 (required by OpenClaw)
# Source: https://github.com/openclaw/openclaw

FROM node:22-bookworm

# Install system dependencies
# - Bun (required for OpenClaw build scripts)
# - SSH client (for bot to connect to remote systems)
# - OpenSCAP (for compliance scanning)
RUN curl -fsSL https://bun.sh/install | bash && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        openssh-client \
        git \
        curl \
        ca-certificates \
        libopenscap25 \
        openscap-scanner \
    && apt-get clean && \
    rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Add Bun to PATH
ENV PATH="/root/.bun/bin:${PATH}"

# Enable pnpm (OpenClaw uses pnpm for package management)
RUN corepack enable

# Set working directory
WORKDIR /app

# Install OpenClaw from npm registry
# Using latest version, will run onboarding on first start
RUN npm install -g openclaw@latest

# Create directories for OpenClaw configuration and workspace
# ~/.openclaw - configuration, API keys, memory
# ~/openclaw/workspace - bot's working files
RUN mkdir -p /home/node/.openclaw && \
    mkdir -p /home/node/openclaw/workspace && \
    mkdir -p /home/node/.ssh && \
    chown -R node:node /home/node

# Copy SCAP content for compliance scanning
RUN mkdir -p /usr/share/xml/scap/ssg/content
COPY docker/scap-content/ssg-debian12-ds.xml /usr/share/xml/scap/ssg/content/

# Copy startup script that exports API keys from secrets
COPY docker/scripts/start-openclaw.sh /usr/local/bin/start-openclaw.sh
RUN chmod +x /usr/local/bin/start-openclaw.sh

# OCI Image labels
LABEL org.opencontainers.image.title="SecureClaw OpenClaw Bot"
LABEL org.opencontainers.image.description="Real OpenClaw platform for therealidallasj bot"
LABEL org.opencontainers.image.vendor="SecureClaw"
LABEL org.opencontainers.image.version="0.2.0"
LABEL org.opencontainers.image.source="https://github.com/idallasj/oneclaw"

# Switch to non-root user (node user has UID 1000)
USER node

# Set home directory
ENV HOME=/home/node
WORKDIR /home/node

# Expose OpenClaw gateway port
EXPOSE 18789

# Healthcheck - verify OpenClaw gateway is responding
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:18789/api/health || exit 1

# Start OpenClaw gateway via wrapper script
# Script exports API keys from Docker secrets before starting OpenClaw
CMD ["/usr/local/bin/start-openclaw.sh"]
