[flake8]
max-line-length = 100
# E203: whitespace before ':' — conflicts with black
# E226/E228: missing whitespace around operator — pre-existing style
# E231: missing whitespace after ',' — pre-existing, black-managed
# E304/E402: decorator/import ordering — pre-existing
# E712/E741: comparison/ambiguous var — pre-existing
# W291/W293: trailing whitespace — pre-existing
# W503: line break before binary operator — black prefers this style
# F401: imported but unused — many re-export imports across the codebase
# F541: f-string without placeholders — pre-existing, non-critical
# F811: redefinition of unused name — intentional overrides in some modules
# F821: undefined name — typing stubs / conditional imports
# F824: __all__ unused name — pre-existing
# F841: local variable assigned but never used — pre-existing, non-critical
ignore = E203,E226,E228,E231,E304,E402,E712,E741,W291,W293,W503,F401,F541,F811,F821,F824,F841
