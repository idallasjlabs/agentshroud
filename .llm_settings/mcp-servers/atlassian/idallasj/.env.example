# =============================================================================
# Atlassian MCP — idallasj tenant (idallasj.atlassian.net)
# =============================================================================
# Copy this file to .env and fill in both values below.
# The real .env is gitignored; this example file is committed.
#
# Credential resolution order in mcp-atlassian.sh and oauth-setup.sh:
#   1. ATLASSIAN_CLIENT_ID / ATLASSIAN_CLIENT_SECRET env vars already exported
#   2. This .env file (sourced via `set -a`) — use this on Linux hosts
#   3. 1Password via `op read 'op://Agent Shroud Bot Credentials/Google [therealidallasj]/...'`
#
# Linux / no-1Password setup:
#   cp .env.example .env
#   # Get OAuth credentials from the Atlassian Developer Console:
#   #   https://developer.atlassian.com/console/myapps/
#   # Account: therealidallasj@gmail.com
#   nano .env   # fill in both vars below, then save
#
# First-time OAuth consent (run once after filling in .env):
#   ./oauth-setup.sh
#   After success: /mcp → reconnect atlassian-idallasj in Claude Code
# =============================================================================

ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
