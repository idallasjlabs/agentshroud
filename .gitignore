# =============================================================================
# AgentShroud .gitignore

# Note:
# - Keep `docker/secrets/*.example` tracked so collaborators have secret templates
# - Keep `memory-backups/backup.log` tracked while ignoring backup tarball artifacts
# SECRETS & CREDENTIALS (CRITICAL)
# Real deployment config (contains personal IPs, phone numbers, hostnames)
agentshroud.yaml
# Docker secrets directory (contains runtime secrets)
docker/secrets/
!docker/secrets/*.example
!docker/secrets/README.md
!docker/secrets/setup-secrets.sh
# agentshroud-dev
docker/agentshroud-dev-secrets/
!docker/agentshroud-dev-secrets/*.example
!docker/agentshroud-dev-secrets/README.md
!docker/agentshroud-dev-secrets/setup-secrets.sh

# Environment variables
.env
.env.*
!.env.example
.llm_env
.llm_env.*
llm_settings/env/.llm_env
llm_settings/mcp-servers/**/.env
security_assessment/.assessment_env

# SSH & GPG keys
.ssh/
*.pem
*.key
!*.key.example
*.p12
*.pfx
*.ppk
id_rsa
id_ed25519
*.asc
*.gpg

# Credential files
aws_credentials
.pgpass
.token
# CHAT HISTORY & SESSION DATA (contains secrets from conversations)
telegram_history.jsonl
telegram_history.jsonl.tgz
tg_export_session.session
*.session
# Early development session notes — purged from git history via filter-repo,
# kept local-only. Contains tokens, passwords, and config dumps.
archive/
# GITLEAKS & SECURITY SCAN REPORTS
*gitleaks-report*.json
# PYTHON
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
.venv-*/
env/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
