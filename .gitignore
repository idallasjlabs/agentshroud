# =============================================================================
# AgentShroud .gitignore
# =============================================================================

# Note:
# - Keep `docker/secrets/*.example` tracked so collaborators have secret templates
# - Keep `memory-backups/backup.log` tracked while ignoring backup tarball artifacts

# =============================================================================
# SECRETS & CREDENTIALS (CRITICAL)
# =============================================================================

# Docker secrets directory (contains runtime secrets)
docker/secrets/
!docker/secrets/
docker/secrets/*
!docker/secrets/README.md
!docker/secrets/setup-secrets.sh
!docker/secrets/*.example

# Environment variables
.env
.env.*
!.env.example
.llm_env
.llm_env.*
llm_settings/env/.llm_env
llm_settings/mcp-servers/**/.env
security_assessment/.assessment_env

# SSH & GPG keys
.ssh/
*.pem
*.key
!*.key.example
*.p12
*.pfx
*.ppk
id_rsa
id_ed25519
*.asc
*.gpg

# Credential files
aws_credentials
.pgpass
.token

# =============================================================================
# CHAT HISTORY & SESSION DATA (contains secrets from conversations)
# =============================================================================

telegram_history.jsonl
telegram_history.jsonl.tgz
tg_export_session.session
*.session

# Early development session notes — purged from git history via filter-repo,
# kept local-only. Contains tokens, passwords, and config dumps.
archive/

# =============================================================================
# GITLEAKS & SECURITY SCAN REPORTS
# =============================================================================

*gitleaks-report*.json

# =============================================================================
# PYTHON
# =============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
.venv-*/
env/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# =============================================================================
# NODE.JS
# =============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache
.node_repl_history

# =============================================================================
# AI/LLM TOOLS
# =============================================================================

# Claude Code
.claude/settings.local.json
.claude/*.local.*
.claude/.cache/
.claude/tmp/
.claude/logs/
.claude/plans/

# Gemini CLI
.gemini/settings.local.json
.gemini/*.local.*

# Codex CLI
.codex/config.local.toml
.codex/*.local.*

# MCP local configs
.mcp.local.json
mcp-config.local.json

# =============================================================================
# IDE & EDITORS
# =============================================================================

.vscode/
*.code-workspace
.idea/
*.iml
*.swp
*.swo
*~
.*.sw[op]

# =============================================================================
# OS FILES
# =============================================================================

.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

# =============================================================================
# BACKUPS & TEMP
# =============================================================================

*.bak
*.backup
*.old
*.tmp
*.temp
.scratch/
tmp/
temp/

# =============================================================================
# DOCKER & BUILD
# =============================================================================

# Docker image exports
*-image.tar
*-image.tar.gz

# =============================================================================
# PROJECT SPECIFIC
# =============================================================================

# Database files
*.db
*.sqlite
*.sqlite3

# History files that may contain credentials
history.env
/secrets/

# Memory backup archives (keep directory/logs, ignore tarballs)
memory-backups/*.tar.gz

# Large data files (adjust as needed)
*.csv.gz
*.parquet.gz

# Data directory (raw/processed data)
data/raw/
data/processed/

# Logs
*.log
logs/
!memory-backups/backup.log

# Lock files
*.lock
!poetry.lock
!Pipfile.lock
!package-lock.json

# Core dumps
core
core.*
CONTINUE.md
**/CONTINUE.md
