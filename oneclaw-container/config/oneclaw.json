{
  "gateway": {
    "bind": "0.0.0.0",
    "port": 18789,
    "auth": {
      "mode": "token"
    },
    "tailscale": {
      "mode": "off"
    }
  },
  "agents": {
    "defaults": {
      "model": "anthropic/claude-opus-4-6",
      "sandbox": {
        "mode": "agent",
        "scope": "agent"
      },
      "workspace": "/app/workspace",
      "maxTurns": 100,
      "temperature": 0.7,
      "systemPrompt": "You are Isaiah's personal AI assistant. Read /app/workspace/IDENTITY, /app/workspace/SOUL.md, and /app/workspace/USER.md to understand how to represent Isaiah authentically. Be direct, technically precise, and security-conscious in all interactions."
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dm": {
        "policy": "pairing"
      },
      "group": {
        "policy": "allowlist"
      }
    },
    "webchat": {
      "enabled": true,
      "port": 18790,
      "title": "Isaiah's Assistant"
    }
  },
  "security": {
    "audit": {
      "enabled": true,
      "logPath": "/app/logs/audit.log",
      "retention": "90d"
    },
    "exec": {
      "approvals": {
        "enabled": true,
        "timeout": 300
      }
    },
    "sandbox": {
      "enabled": true,
      "allowedTools": ["bash", "read", "write", "sessions"]
    }
  },
  "skills": {
    "registry": "https://clawhub.ai",
    "autoUpdate": false,
    "verifySignatures": true
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "userAgent": "OpenClaw/IsaiahAssistant"
  },
  "logging": {
    "level": "info",
    "format": "json",
    "outputs": ["file", "console"]
  }
}
