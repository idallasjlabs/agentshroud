# DEPRECATED: Use docker/Dockerfile.agentshroud instead. This Containerfile is retained for reference only.
# AgentShroud OpenClaw Container - Real OpenClaw Platform
# Goal: Full OpenClaw features (agents, skills, MCP) with bot identity
# Base: Node.js 22 (required by OpenClaw)
# Source: https://github.com/openclaw/openclaw

FROM node:22-bookworm-slim
# TODO: Pin to digest for production: FROM node:22-bookworm-slim@sha256:<digest>
# Update with: docker pull node:22-bookworm-slim && docker inspect --format='{{index .RepoDigests 0}}' node:22-bookworm-slim

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        openssh-client \
        git \
        curl \
        ca-certificates \
        unzip \
        libopenscap25 \
        openscap-scanner \
        gosu \
    && apt-get clean && \
    rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Install bun via npm (avoids curl|bash supply chain risk)
RUN npm install -g bun@latest

# Enable pnpm (OpenClaw uses pnpm for package management)
RUN corepack enable

# Set working directory
WORKDIR /app

# Install OpenClaw from npm registry
# TODO: Pin to specific version for reproducible builds: openclaw@X.Y.Z
RUN npm install -g openclaw@latest

# Install Playwright for browser automation (browser-fetch skill)
RUN npm install -g playwright@latest && \
    npx playwright install --with-deps chromium

# Install 1Password CLI for secure secret management (multi-arch)
RUN ARCH=$(dpkg --print-architecture) && \
    curl -L -o /tmp/op.zip "https://cache.agilebits.com/dist/1P/op2/pkg/v2.32.0/op_linux_${ARCH}_v2.32.0.zip" && \
    unzip -q /tmp/op.zip -d /tmp/ && \
    mv /tmp/op /usr/local/bin/op && \
    chmod +x /usr/local/bin/op && \
    rm -f /tmp/op.zip /tmp/op.sig

# Create directories for OpenClaw configuration and workspace
RUN mkdir -p /home/node/.openclaw && \
    mkdir -p /home/node/openclaw/workspace && \
    mkdir -p /home/node/.ssh && \
    chown -R node:node /home/node

# Copy SCAP content for compliance scanning
RUN mkdir -p /usr/share/xml/scap/ssg/content
COPY docker/scap-content/ssg-debian12-ds.xml /usr/share/xml/scap/ssg/content/

# Copy startup and utility scripts
COPY docker/scripts/op-auth-common.sh /usr/local/bin/op-auth-common.sh
COPY docker/scripts/start-openclaw.sh /usr/local/bin/start-openclaw.sh
COPY docker/scripts/op-wrapper.sh /usr/local/bin/op-wrapper.sh
COPY docker/scripts/get-credential.sh /usr/local/bin/get-credential
COPY docker/scripts/1password-skill.sh /usr/local/bin/1password-skill
COPY docker/scripts/entrypoint-openclaw.sh /usr/local/bin/entrypoint-openclaw.sh
RUN chmod +x /usr/local/bin/op-auth-common.sh \
    /usr/local/bin/start-openclaw.sh \
    /usr/local/bin/op-wrapper.sh \
    /usr/local/bin/get-credential \
    /usr/local/bin/1password-skill \
    /usr/local/bin/entrypoint-openclaw.sh

# Copy documentation
COPY docker/bot-capabilities.md /app/bot-capabilities.md
COPY docker/SYSTEM-INSTRUCTIONS-SECURITY.md /app/SYSTEM-INSTRUCTIONS-SECURITY.md

# OCI Image labels
LABEL org.opencontainers.image.title="AgentShroud OpenClaw Bot"
LABEL org.opencontainers.image.description="Real OpenClaw platform for agentshroud bot"
LABEL org.opencontainers.image.vendor="AgentShroud"
LABEL org.opencontainers.image.version="0.2.0"
LABEL org.opencontainers.image.source="https://github.com/idallasjlabs/agentshroud"

# Switch to non-root user (node user has UID 1000)
USER node
ENV HOME=/home/node
WORKDIR /home/node

# Expose OpenClaw gateway port
EXPOSE 18789

# Healthcheck
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:18789/api/health || exit 1

# Start OpenClaw gateway via wrapper script
CMD ["/usr/local/bin/start-openclaw.sh"]
