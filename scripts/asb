#!/usr/bin/env bash
# asb — AgentShroud Bot helper
# Works on any server: resolves compose override file from hostname.
# Usage: asb {build|up|down|rebuild|pull|status|logs [service]|test}

set -euo pipefail

# Ensure the Colima Docker socket is group-writable (required on macOS with Colima)
chmod g+rw /Users/ijefferson.admin/.colima/default/docker.sock 2>/dev/null || true

HOST=$(hostname -s)
SCRIPT_PATH="${BASH_SOURCE[0]}"
[ -L "$SCRIPT_PATH" ] && SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
REPO_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

# Project name: "agentshroud" for prod, "agentshroud-bot" for bot account
if [ "$USER" = "agentshroud-bot" ]; then
  PROJECT="agentshroud-bot"
else
  PROJECT="agentshroud"
fi

if [ "$USER" = "agentshroud-bot" ]; then
  OVERRIDE="$REPO_DIR/docker/docker-compose.agentshroud-bot.${HOST}.yml"
  if [ ! -f "$OVERRIDE" ]; then
    echo "ERROR: no compose override for host '${HOST}' — expected: $OVERRIDE" >&2
    exit 1
  fi
  COMPOSE="docker compose -f $REPO_DIR/docker/docker-compose.yml -f $OVERRIDE -p $PROJECT"
else
  COMPOSE="docker compose -f $REPO_DIR/docker/docker-compose.yml -p $PROJECT"
fi

# ── Instance banner ──────────────────────────────────────────────────────────
# Prints a one-line banner identifying which instance asb is operating on.
# Makes PROD vs DEV immediately obvious when multiple stacks run on the same host.
_asb_banner() {
  local label gw_port bot_port
  if [ "$USER" = "agentshroud-bot" ]; then
    label="DEV"
    case "$HOST" in
      marvin*) gw_port=9080; bot_port=19789 ;;
      *)       gw_port=8080; bot_port=18790 ;;
    esac
  else
    label="PROD"
    gw_port=8080
    bot_port=18790
  fi
  printf '\n== AgentShroud™ [%s] %s@%s  |  project: %s  |  gw: :%s  bot: :%s ==\n\n' \
    "$label" "$USER" "$HOST" "$PROJECT" "$gw_port" "$bot_port"
}

# ── Ephemeral secrets injection ──────────────────────────────────────────────
# Reads secrets from the credential backend (1Password/Keychain/secret-tool)
# into a mktemp directory, generates a compose override that remaps all
# secrets: file: paths to the tmpdir, then cleans up via EXIT trap.
# Secret files exist on the host only for the duration of `docker compose up`.
setup_ephemeral_secrets() {
  local tmpdir
  # Colima only mounts $HOME by default — neither $TMPDIR (/var/folders/) nor
  # /tmp is shared into the VM. Use $HOME/.agentshroud/.asb-tmp so Docker can
  # always reach the secrets via the mounted home directory.
  mkdir -p "$HOME/.agentshroud/.asb-tmp"
  tmpdir="$(mktemp -d "$HOME/.agentshroud/.asb-tmp/asb-secrets.XXXXXX")"
  trap '[[ -n "${tmpdir:-}" ]] && rm -rf "$tmpdir"' EXIT

  # Extract secrets from credential backend → tmpdir (suppress interactive banner)
  AGENTSHROUD_SECRETS_DIR="$tmpdir" "$REPO_DIR/docker/setup-secrets.sh" extract || {
    echo "ERROR: secret extraction failed" >&2; exit 1
  }

  # Create empty placeholders for optional secrets so Docker Compose does not
  # refuse to start when a token was not stored (Slack, OpenAI, Google API key).
  for optional in slack_bot_token slack_signing_secret slack_app_token \
                  openai_api_key google_api_key; do
    [ -f "$tmpdir/${optional}.txt" ] || touch "$tmpdir/${optional}.txt"
  done

  # The Docker daemon inside the Colima VM runs under a different UID and cannot
  # stat files created with chmod 600. Relax permissions on this ephemeral tmpdir
  # (including placeholders just created) so the daemon can bind-mount the files.
  # The directory is cleaned up on EXIT.
  chmod 755 "$tmpdir"
  chmod 644 "$tmpdir"/*.txt 2>/dev/null || true

  # Determine which telegram_bot_token variant to use for this host/user.
  # Falls back to production token if the host-specific token was not stored.
  local tg_file="telegram_bot_token_production.txt"
  if [ "$USER" = "agentshroud-bot" ]; then
    local host_tg_file
    case "$HOST" in
      marvin*)       host_tg_file="telegram_bot_token_marvin.txt" ;;
      trillian*)     host_tg_file="telegram_bot_token_trillian.txt" ;;
      raspberrypi*)  host_tg_file="telegram_bot_token_rpi.txt" ;;
      *)             host_tg_file="" ;;
    esac
    if [[ -n "$host_tg_file" && -s "$tmpdir/$host_tg_file" ]]; then
      tg_file="$host_tg_file"
    else
      echo "  NOTE: host-specific token '$host_tg_file' not found — using production token"
    fi
  fi

  # Generate a compose override that redirects all secrets: file: entries to
  # the tmpdir. This override is appended last in the -f chain so it wins over
  # any base or host-specific overlay definitions.
  local override="$tmpdir/docker-compose.secrets-override.yml"
  cat > "$override" << YAML
secrets:
  gateway_password:
    file: ${tmpdir}/gateway_password.txt
  anthropic_oauth_token:
    file: ${tmpdir}/anthropic_oauth_token.txt
  openai_api_key:
    file: ${tmpdir}/openai_api_key.txt
  google_api_key:
    file: ${tmpdir}/google_api_key.txt
  1password_bot_email:
    file: ${tmpdir}/1password_bot_email.txt
  1password_bot_master_password:
    file: ${tmpdir}/1password_bot_master_password.txt
  1password_bot_secret_key:
    file: ${tmpdir}/1password_bot_secret_key.txt
  telegram_bot_token:
    file: ${tmpdir}/${tg_file}
  slack_bot_token:
    file: ${tmpdir}/slack_bot_token.txt
  slack_signing_secret:
    file: ${tmpdir}/slack_signing_secret.txt
  slack_app_token:
    file: ${tmpdir}/slack_app_token.txt
YAML

  COMPOSE="$COMPOSE -f $override"
}

# ── Docker disk reclamation ──────────────────────────────────────────────────
# Removes stopped containers, dangling images, unused networks, and BuildKit
# cache to reclaim disk on the Colima VM before builds. Safe to run without
# stopping running containers — running containers and named volumes are NOT removed.
# Each step is wrapped in a 30-second timeout — BuildKit prune is known to hang
# on Colima when the daemon is in a bad state.
_prune_docker() {
  echo "Pruning stopped containers, dangling images, and BuildKit cache..."
  timeout 30 docker container prune -f 2>/dev/null || true
  timeout 30 docker image prune -f 2>/dev/null || true
  timeout 30 docker network prune -f 2>/dev/null || true
  timeout 60 docker builder prune -f 2>/dev/null \
    || timeout 60 docker buildx prune -f 2>/dev/null \
    || echo "  BuildKit prune timed out — continuing anyway"
  echo "Docker prune complete."
}

_asb_banner

# ── Config file pre-flight ───────────────────────────────────────────────────
# agentshroud.yaml is .gitignore'd (per-host config). If the file is missing,
# Docker creates an empty directory as a bind-mount placeholder, crashing the
# gateway with IsADirectoryError. Auto-create from example if needed.
_CONFIG="$REPO_DIR/agentshroud.yaml"
_CONFIG_EXAMPLE="$REPO_DIR/agentshroud.yaml.example"
if [ -d "$_CONFIG" ]; then
  echo "WARNING: agentshroud.yaml is a directory (Docker placeholder) — removing"
  rm -rf "$_CONFIG"
fi
if [ ! -f "$_CONFIG" ] && [ -f "$_CONFIG_EXAMPLE" ]; then
  echo "Creating agentshroud.yaml from example template (edit $REPO_DIR/agentshroud.yaml to customize)"
  cp "$_CONFIG_EXAMPLE" "$_CONFIG"
fi

case "${1:-}" in
  build)
    _prune_docker
    $COMPOSE build --no-cache
    ;;
  up)
    setup_ephemeral_secrets
    $COMPOSE up -d
    ;;
  down)    $COMPOSE down ;;
  rebuild)
    _prune_docker
    setup_ephemeral_secrets
    $COMPOSE build --no-cache && $COMPOSE up -d
    ;;
  clean-rebuild)
    echo "This will remove containers, prune stale volumes, and rebuild from scratch."
    echo "Persistent data (workspace, config, SSH keys, browsers) is PRESERVED."
    read -r -p "Continue? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }
    $COMPOSE down
    for vol in gateway-data clamav-db; do
      docker volume rm "${PROJECT}_${vol}" 2>/dev/null && echo "  Removed ${PROJECT}_${vol}" || true
    done
    _prune_docker
    setup_ephemeral_secrets
    $COMPOSE build --no-cache
    $COMPOSE up -d
    echo "Clean rebuild complete."
    ;;
  pull)    cd "$REPO_DIR" && git pull --rebase ;;
  status)  $COMPOSE ps ;;
  logs)    $COMPOSE logs -f --tail=100 ${2:-} ;;
  test)    $COMPOSE exec gateway python -m pytest gateway/tests/ -q ;;
  *)
    echo "Usage: asb {build|up|down|rebuild|clean-rebuild|pull|status|logs [service]|test}"
    exit 1
    ;;
esac
