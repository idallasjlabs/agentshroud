# Telegram API Credentials (get from https://my.telegram.org)
API_ID=your_api_id
API_HASH=your_api_hash

# Owner Account
OWNER_PHONE=+1234567890
OWNER_SESSION=owner_session

# Collaborator Account
COLLABORATOR_PHONE=+1987654321
COLLABORATOR_SESSION=collaborator_session

# Bot Username
BOT_USERNAME=@agentshroud_bot

# Optional input overrides
# Leave unset to use:
#   security_assessment/inputs/blue_team_inputs.txt
#   security_assessment/inputs/red_team_inputs.txt
# BLUE_INPUT_FILE=inputs/blue_team_inputs.txt
# RED_INPUT_FILE=inputs/red_team_inputs.txt
