# OneClaw — Maximum Security Configuration
# All security features enabled, strictest settings

# Required: Authentication token
GATEWAY_AUTH_TOKEN=CHANGE_ME

# Gateway
GATEWAY_BIND=127.0.0.1
GATEWAY_PORT=8080
AUTH_METHOD=shared_secret

# PII Sanitization — all types enabled
PII_REDACTION=true
PII_ENGINE=presidio
PII_TYPES=SSN,CREDIT_CARD,PHONE_NUMBER,EMAIL_ADDRESS,STREET_ADDRESS,IP_ADDRESS,IBAN,PASSPORT

# Approval Queue — require approval for everything
APPROVAL_QUEUE=true
REQUIRE_APPROVAL_FOR=email_sending,file_deletion,external_api_calls,skill_installation,ssh_commands,file_upload,config_changes

# Audit Ledger — long retention
LEDGER_DATABASE=sqlite:///data/ledger.db
LEDGER_RETENTION_DAYS=365

# Prompt Guard
PROMPT_GUARD_ENABLED=true
PROMPT_GUARD_STRICT=true

# Egress Filter — strict allowlist
EGRESS_FILTER_ENABLED=true
EGRESS_ALLOWED_HOSTS=api.openai.com,api.anthropic.com
EGRESS_BLOCK_LAN=true
EGRESS_BLOCK_METADATA=true

# Trust Manager
TRUST_MANAGER_ENABLED=true
TRUST_VERIFY_ON_BOOT=true

# Drift Detector
DRIFT_DETECTOR_ENABLED=true
DRIFT_CHECK_INTERVAL_SECONDS=60

# Encrypted Store
ENCRYPTED_STORE_ENABLED=true

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3000
WEBSOCKET_ENABLED=true

# Kill Switch
KILL_SWITCH_ENABLED=true
KILL_SWITCH_ACTION=shutdown

# Container Hardening — maximum isolation
CONTAINER_RUNTIME=podman
ROOTLESS=true
READ_ONLY_ROOTFS=true
MEMORY_LIMIT=2g
MEMORY_RESERVATION=1g
CPU_LIMIT=1
PIDS_LIMIT=512
NO_NEW_PRIVILEGES=true
SECCOMP_PROFILE=docker/seccomp/agentshroud-arm64.json

# Network — strict
TAILSCALE=true
INTERNET_ONLY=true
BLOCK_RFC1918=true

# SSH Proxy — approval required, no auto-approve
SSH_ENABLED=true
SSH_REQUIRE_APPROVAL=true
SSH_AUTO_APPROVE_COMMANDS=
SSH_MAX_SESSION_SECONDS=15

# Logging
LOG_LEVEL=DEBUG
LOG_MAX_SIZE_MB=50
LOG_MAX_FILES=10

# Telemetry — all disabled
TELEMETRY_DISABLED=true
DO_NOT_TRACK=true
