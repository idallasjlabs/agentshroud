# OneClaw — Recommended Production Configuration
# Good balance of security and usability

# Required: Authentication token
GATEWAY_AUTH_TOKEN=CHANGE_ME

# Gateway
GATEWAY_BIND=127.0.0.1
GATEWAY_PORT=8080
AUTH_METHOD=shared_secret

# PII Sanitization
PII_REDACTION=true
PII_ENGINE=presidio

# Approval Queue
APPROVAL_QUEUE=true
REQUIRE_APPROVAL_FOR=email_sending,file_deletion,external_api_calls,skill_installation

# Audit Ledger
LEDGER_DATABASE=sqlite:///data/ledger.db
LEDGER_RETENTION_DAYS=90

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3000
WEBSOCKET_ENABLED=true

# Kill Switch
KILL_SWITCH_ENABLED=true
KILL_SWITCH_ACTION=freeze

# Container Hardening
CONTAINER_RUNTIME=podman
ROOTLESS=true
READ_ONLY_ROOTFS=true
MEMORY_LIMIT=4g
CPU_LIMIT=2
PIDS_LIMIT=1024

# Network
TAILSCALE=true
INTERNET_ONLY=true

# SSH Proxy
SSH_ENABLED=true
SSH_REQUIRE_APPROVAL=true

# Logging
LOG_LEVEL=INFO
LOG_MAX_SIZE_MB=10
LOG_MAX_FILES=3
